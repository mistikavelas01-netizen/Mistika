# ===========================================
# Autenticación
# ===========================================
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ===========================================
# URLs de la aplicación
# ===========================================
# Base URL pública (correos, back_urls MP, sitemap, robots).
# Desarrollo: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Opcional: envío gratis global (true = no se cobra envío)
# NEXT_PUBLIC_FREE_SHIPPING_ENABLED=false

# ===========================================
# Firebase (Firestore)
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Firebase Admin SDK (solo server-side, nunca NEXT_PUBLIC_)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ===========================================
# Email (Resend)
# ===========================================
RESEND_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Mistika

# ===========================================
# Cloudinary (subida de imágenes)
# ===========================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# Mercado Pago (Checkout Pro)
# ===========================================
MERCADOPAGO_ACCESS_TOKEN=
# Opcional: excluir tarjetas prepago (recomendado true en producción, false en sandbox)
# MERCADOPAGO_EXCLUDE_PREPAID=false
# Opcional: forzar solo estados approved/rejected (sin pending/in_process)
# MERCADOPAGO_BINARY_MODE=true
# Opcional: validar firma del webhook
# MERCADOPAGO_WEBHOOK_SECRET=
# Opcional: forzar sandbox en frontend (tarjetas de prueba)
# NEXT_PUBLIC_MERCADOPAGO_USE_SANDBOX=true

# ===========================================
# Opcional
# ===========================================
# Solo si usas app/api/route.ts como proxy a otro backend
# BACKEND_URL=http://localhost:3001

# ===========================================
# Variables de contacto
# ===========================================
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_INSTAGRAM_URL=
# Enlace de WhatsApp (wa.me). Ejemplo: https://wa.me/521234567890 (código de país + número, sin + ni espacios)
NEXT_PUBLIC_WHATSAPP_URL=